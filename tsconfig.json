{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@components/*": ["app/shared/components/*"],
      "@themes/*": ["app/shared/themes/*"],
      "@screens/*": ["app/shared/screens/*"],
      "@interfaces/*": ["app/shared/interfaces/*"],
      "@web/*": ["app/modules/web/*"],
      "@mobile/*": ["app/modules/mobile/*"]
    }
  }
}
